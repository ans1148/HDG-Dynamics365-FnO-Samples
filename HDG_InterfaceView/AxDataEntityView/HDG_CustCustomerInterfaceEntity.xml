		<Methods>
			<Method>
				<Name>latestModifiedDateTime</Name>
				<Source><![CDATA[
    private static str latestModifiedDateTime()
    {
        str custTableModifiedDateTime = SysComputedColumn::returnField(
            dataentityviewstr(HDG_CustCustomerInterfaceEntity),
            dataEntityDataSourceStr(HDG_CustCustomerInterfaceEntity, CustTable),
            fieldStr(CustTable, ModifiedDateTime));

        str dirPartyModifiedDateTime = SysComputedColumn::returnField(
            dataentityviewstr(HDG_CustCustomerInterfaceEntity),
            dataEntityDataSourceStr(HDG_CustCustomerInterfaceEntity, DirPartyTable),
            fieldStr(DirPartyTable, ModifiedDateTime));

        str emailModifiedDateTime = SysComputedColumn::returnField(
            dataentityviewstr(HDG_CustCustomerInterfaceEntity),
            dataEntityDataSourceStr(HDG_CustCustomerInterfaceEntity, PrimaryContactEmail),
            fieldStr(LogisticsElectronicAddress, ModifiedDateTime));

        str phoneModifiedDateTime = SysComputedColumn::returnField(
            dataentityviewstr(HDG_CustCustomerInterfaceEntity),
            dataEntityDataSourceStr(HDG_CustCustomerInterfaceEntity, PrimaryContactPhone),
            fieldStr(LogisticsElectronicAddress, ModifiedDateTime));

        str deliveryAddressModifiedDateTime = SysComputedColumn::returnField(
            dataentityviewstr(HDG_CustCustomerInterfaceEntity),
            dataEntityDataSourceStr(HDG_CustCustomerInterfaceEntity, DeliveryLogisticsPostalAddressBaseEntity),
            fieldStr(LogisticsPostalAddressBaseEntity, HDG_LogisticsPostalAddressModifiedDateTime));

        str invoiceAddressModifiedDateTime = SysComputedColumn::returnField(
            dataentityviewstr(HDG_CustCustomerInterfaceEntity),
            dataEntityDataSourceStr(HDG_CustCustomerInterfaceEntity, InvoiceLogisticsPostalAddressBaseEntity),
            fieldStr(LogisticsPostalAddressBaseEntity, HDG_LogisticsPostalAddressModifiedDateTime));

        return strFmt("(SELECT MAX(MaxDateTime) FROM (VALUES " +
            "(COALESCE(%1, '1900-01-01')), " +
            "(COALESCE(%2, '1900-01-01')), " +
            "(COALESCE(%3, '1900-01-01')), " +
            "(COALESCE(%4, '1900-01-01')), " +
            "(COALESCE(%5, '1900-01-01')), " +
            "(COALESCE(%6, '1900-01-01'))" +
            ") AS AllDates(MaxDateTime))",
            custTableModifiedDateTime,
            dirPartyModifiedDateTime,
            emailModifiedDateTime,
            phoneModifiedDateTime,
            deliveryAddressModifiedDateTime,
            invoiceAddressModifiedDateTime);
    }

]]></Source>
			</Method>
		</Methods>
